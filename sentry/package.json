{
  "name": "sonnet-sentry",
  "version": "1.0.0",
  "description": "Sentry sdk core",
  "type": "module",
  "keywords": [
    "sentry",
    "sdk",
    "core"
  ],
  "author": "github.com/161043261",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./plugins/perf": {
      "import": "./dist/plugins/perf/index.js",
      "require": "./dist/plugins/perf/index.cjs",
      "types": "./dist/plugins/perf/index.d.ts"
    },
    "./plugins/record": {
      "import": "./dist/plugins/record/index.js",
      "require": "./dist/plugins/record/index.cjs",
      "types": "./dist/plugins/record/index.d.ts"
    },
    "./plugins/exposure": {
      "import": "./dist/plugins/exposure/index.js",
      "require": "./dist/plugins/exposure/index.cjs",
      "types": "./dist/plugins/exposure/index.d.ts"
    }
  },
  "dependencies": {
    "@rrweb/record": "2.0.0-alpha.18",
    "pako": "^2.1.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "rollup": "^4.60.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@types/pako": "^2.0.4",
    "react": "^19.2.3",
    "vue": "^3.5.26"
  }
}
